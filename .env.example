# Modelo: Gemini (Google AI) o vía OpenRouter (LiteLLM)
GOOGLE_API_KEY=

# --- Opción A: OpenAI (pago, estable, tools bien soportados) ---
# Si defines OPENAI_API_KEY, se usa OpenAI y se ignora OpenRouter.
# Puedes usar API key normal o token de Service Account (sk-svcacct-...).
OPENAI_API_KEY=
# Opcional: modelo (por defecto gpt-4o-mini). Para 4 mini: openai/gpt-4o-mini
# OPENAI_MODEL=

# --- Opción B: OpenRouter (modelos free; puede dar 404 o upstream errors) ---
# Solo se usa si OPENAI_API_KEY no está definida.
OPENROUTER_API_KEY=
# Opcional: modelo (por defecto meta-llama/llama-3.2-3b-instruct:free)
# OPENROUTER_MODEL=

# MCP: Freesound y RedPanal
FREESOUND_API_KEY=
REDPANAL_USER=
REDPANAL_PASSWORD=
